<section id="about" class="mx-auto max-w-7xl px-5 py-20 sm:px-8 sm:py-28">
  <div class="grid gap-10 md:grid-cols-[1fr_1.6fr] md:gap-16">
    <div class="reveal flex flex-col justify-between">
      <h2 class="font-display text-2xl italic">About Us</h2>
      <p class="mt-10 max-w-[38ch] text-[0.95rem] leading-relaxed text-ink-soft md:mt-0">

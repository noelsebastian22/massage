<section id="top" class="relative px-3 pt-3 sm:px-4 sm:pt-4">
  <div class="hero-frame relative mt-16 overflow-hidden rounded-3xl">
    <img
      src="/images/hero.jpg"
      alt="A massage therapist working gently on a client's shoulders in a warm, plant-filled treatment room"
      class="hero-img h-[72vh] min-h-[480px] w-full object-cover sm:h-[78vh]"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/55 via-ink/10 to-ink/20" aria-hidden="true"></div>

    <div class="absolute inset-x-0 bottom-0 px-6 pb-10 sm:px-12 sm:pb-14">
      <p class="hero-line mb-4 text-[0.8rem] font-medium tracking-[0.22em] text-white/80 uppercase">
        Cloud 3 Massage Therapy &middot; Blackheath, Blue Mountains
      </p>
      <h1 class="font-display text-[clamp(2.6rem,7.5vw,5.5rem)] leading-[1.05] text-white italic">
        <span class="hero-word">Feel.</span>
        <span class="hero-word">Breathe.</span>
        <span class="hero-word">Release.</span>
      </h1>
    </div>
  </div>
</section>

<style>
  /* Slow settle-in for the hero image; words rise in sequence */
  html.js .hero-img {
    animation: hero-settle 2.4s var(--ease-out-expo) both;
  }
  html.js .hero-line {
    animation: hero-rise 1s var(--ease-out-quint) 0.9s both;
  }
  html.js .hero-word {
    display: inline-block;
    animation: hero-rise 1.1s var(--ease-out-quint) both;
  }
  html.js .hero-word:nth-child(1) {
    animation-delay: 0.15s;
  }
  html.js .hero-word:nth-child(2) {
    animation-delay: 0.35s;
  }
  html.js .hero-word:nth-child(3) {
    animation-delay: 0.55s;
  }

  @keyframes hero-settle {
    from {
      transform: scale(1.06);
    }
    to {
      transform: scale(1);
    }
  }
  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(0.6em);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html.js .hero-img,
    html.js .hero-line,
    html.js .hero-word {
      animation: hero-fade 0.6s ease both;
    }
    @keyframes hero-fade {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  }
</style>

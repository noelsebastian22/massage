---
const links = [
  { href: '#about', label: 'About' },
  { href: '#treatments', label: 'Treatments' },
  { href: '#experiences', label: 'Experiences' },
  { href: '#therapist', label: 'Your Therapist' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="fixed inset-x-0 top-0 z-(--z-header) bg-pine/95 backdrop-blur-sm">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-5 sm:px-8">
    <a href="#top" class="flex items-center gap-2.5 text-pine-mist">
      <svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true">
        <path
          d="M7 17c-2.8 0-4.5-1.9-4.5-4.2 0-2.1 1.6-3.9 3.7-4.2C6.7 5.6 9.1 3.5 12 3.5c3.2 0 5.8 2.5 6 5.7 2.5.2 4.5 2.2 4.5 4.7 0 2.6-2.1 4.6-4.7 4.6"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
        />
        <path d="M9 21.5h8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
      </svg>
      <span class="font-display text-xl tracking-wide">Cloud 3</span>
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-8 md:flex">
      {
        links.map(({ href, label }) => (
          <a
            href={href}
            class="text-[0.82rem] font-medium tracking-[0.04em] text-pine-mist/85 transition-colors duration-300 hover:text-white"
          >
            {label}
          </a>
        ))
      }
    </nav>

    <a
      href="#contact"
      class="btn-pill border border-pine-mist/40 px-5 py-2.5 text-pine-mist hover:bg-pine-mist hover:text-pine"
    >
      Book Now
    </a>
  </div>
</header>

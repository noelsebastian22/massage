---
const links = [
  { href: '#about', label: 'About' },
  { href: '#treatments', label: 'Treatments' },
  { href: '#experiences', label: 'Experiences' },
  { href: '#therapist', label: 'Your Therapist' },
  { href: '#contact', label: 'Contact' },
];

const year = new Date().getFullYear();
---

<footer class="bg-pine text-pine-mist">
  <div class="mx-auto max-w-7xl px-5 py-14 sm:px-8">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <div>
        <a href="#top" class="flex items-center gap-2.5">
          <svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true">
            <path
              d="M7 17c-2.8 0-4.5-1.9-4.5-4.2 0-2.1 1.6-3.9 3.7-4.2C6.7 5.6 9.1 3.5 12 3.5c3.2 0 5.8 2.5 6 5.7 2.5.2 4.5 2.2 4.5 4.7 0 2.6-2.1 4.6-4.7 4.6"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
            />
            <path d="M9 21.5h8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
          <span class="font-display text-xl tracking-wide">Cloud 3</span>
        </a>
        <p class="mt-4 font-display text-lg italic">Feel. Breathe. Release.</p>
      </div>

      <nav aria-label="Footer" class="flex flex-wrap gap-x-8 gap-y-3">
        {
          links.map(({ href, label }) => (
            <a href={href} class="text-sm text-pine-mist/85 transition-colors duration-300 hover:text-white">
              {label}
            </a>
          ))
        }
      </nav>

      <address class="text-sm leading-relaxed text-pine-mist/85 not-italic">
        <p class="font-medium text-white">Contact Us Here</p>
        <p class="mt-3">16 Lawrence Street, Blackheath NSW 2785</p>
        <p class="mt-1"><a href="tel:+61421582509" class="hover:text-white">0421 582 509</a></p>
        <p class="mt-1">
          <a href="mailto:cloud3massage@hotmail.com" class="hover:text-white">cloud3massage@hotmail.com</a>
        </p>
      </address>
    </div>

    <div class="mt-12 border-t border-pine-mist/20 pt-6 text-xs leading-relaxed text-pine-mist/65">
      <p>
        We acknowledge the Darug and Gundungurra people, Traditional Custodians of the land on
        which the clinic stands, and pay respect to Elders past and present.
      </p>
      <p class="mt-2">
        &copy; {year} Cloud 3 Massage Therapy &middot; Gerhard Hassler &middot; ABN 16 705 116 674
      </p>
    </div>
  </div>
</footer>
